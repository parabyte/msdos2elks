#!/bin/sh
# Configure msdos2elks for the local host compiler.
#
# This is intentionally small and dependency-light.  It writes config.mk for
# Make, verifies that the selected compiler can build a hosted C program, and
# leaves the actual converter source untouched.

set -eu

prefix=/usr/local
bindir='$(PREFIX)/bin'

: "${CC:=cc}"
: "${CPPFLAGS:=}"
: "${CFLAGS:=-O2 -g}"
: "${WARN_CFLAGS:=-Wall -Wextra -std=c99}"
: "${LDFLAGS:=}"
: "${INSTALL:=install}"

usage ()
{
  cat <<EOF
Usage: ./configure [OPTIONS]

Options:
  --prefix=PATH          installation prefix, default /usr/local
  --bindir=PATH          program installation directory
  --cc=CC                C compiler command, default from CC or cc
  --cflags=FLAGS         C compiler flags, default from CFLAGS or -O2 -g
  --ldflags=FLAGS        linker flags, default from LDFLAGS
  --enable-sanitizers    add address and undefined-behavior sanitizer flags
  -h, --help             show this help

Environment:
  CPPFLAGS, WARN_CFLAGS, INSTALL, and DESTDIR are honored by Make.
EOF
}

for opt in "$@"; do
  case "$opt" in
    --prefix=*)
      prefix=${opt#*=}
      ;;
    --bindir=*)
      bindir=${opt#*=}
      ;;
    --cc=*)
      CC=${opt#*=}
      ;;
    --cflags=*)
      CFLAGS=${opt#*=}
      ;;
    --ldflags=*)
      LDFLAGS=${opt#*=}
      ;;
    --enable-sanitizers)
      CFLAGS="$CFLAGS -fsanitize=address,undefined -fno-omit-frame-pointer"
      LDFLAGS="$LDFLAGS -fsanitize=address,undefined"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'configure: unknown option: %s\n' "$opt" >&2
      usage >&2
      exit 2
      ;;
  esac
done

rm -f conftest conftest.c conftest.o
trap 'rm -f conftest conftest.c conftest.o' EXIT HUP INT TERM

{
  printf 'msdos2elks configure log\n'
  printf 'CC=%s\n' "$CC"
  printf 'CPPFLAGS=%s\n' "$CPPFLAGS"
  printf 'CFLAGS=%s\n' "$CFLAGS"
  printf 'WARN_CFLAGS=%s\n' "$WARN_CFLAGS"
  printf 'LDFLAGS=%s\n' "$LDFLAGS"
} > config.log

cat > conftest.c <<'EOF'
int
main (void)
{
  return 0;
}
EOF

if ! $CC $CPPFLAGS $CFLAGS $WARN_CFLAGS -o conftest conftest.c $LDFLAGS \
       >> config.log 2>&1; then
  printf 'configure: selected compiler failed; see config.log\n' >&2
  tail -20 config.log >&2 || true
  exit 1
fi

cat > config.mk <<EOF
# Generated by ./configure.  Edit by hand or re-run configure.
CC = $CC
CPPFLAGS = $CPPFLAGS
CFLAGS = $CFLAGS
WARN_CFLAGS = $WARN_CFLAGS
LDFLAGS = $LDFLAGS
PREFIX = $prefix
BINDIR = $bindir
INSTALL = $INSTALL
EOF

cat > config.status <<'EOF'
#!/bin/sh
printf '%s\n' 'Run ./configure again to regenerate config.mk.'
EOF
chmod +x config.status

printf 'configured msdos2elks\n'
printf '  compiler: %s\n' "$CC"
printf '  cflags:   %s %s\n' "$CFLAGS" "$WARN_CFLAGS"
printf '  prefix:   %s\n' "$prefix"
printf '  bindir:   %s\n' "$bindir"
